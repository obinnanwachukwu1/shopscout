{
  "manifest_version": 3,
  "name": "ShopScout",
  "version": "1.0.0",
  "description": "AI-powered shopping co-pilot for Amazon and eBay. Get evidence-backed product verdicts with price analysis, review sentiment, and seller trust ratings.",
  "permissions": [
    "storage",
    "activeTab",
    "sidePanel",
    "scripting",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://www.amazon.com/*",
    "https://www.ebay.com/*",
    "https://api.anthropic.com/*",
    "https://html.duckduckgo.com/*",
    "https://duckduckgo.com/*",
    "https://*.duckduckgo.com/*",
    "https://support.apple.com/*",
    "https://www.simplymac.com/*",
    "https://www.ifixit.com/*",
    "https://everymac.com/*",
    "http://127.0.0.1:9000/*",
    "http://localhost:9000/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "cors-header-rules",
        "enabled": true,
        "path": "rules/modify-headers.json"
      }
    ]
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.com/*/dp/*",
        "https://www.amazon.com/dp/*",
        "https://www.ebay.com/itm/*"
      ],
      "js": ["src/modules/amazon-extractor.js", "src/modules/ebay-extractor.js", "content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "sidepanel.html",
    "default_title": "Open ShopScout",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "chat.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
